# Copy this to .env for local development if you use python-dotenv later.
# Do not commit real API keys.

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
API_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash-lite
FALLBACK_MODEL_NAME=gemini-3.5-flash
CAPTURE_INTERVAL_SECONDS=6
API_IMAGE_MAX_DIMENSION=768
API_IMAGE_JPEG_QUALITY=72
API_MAX_OUTPUT_TOKENS=512
DANMAKU_USE_STREAMING_API=true
DANMAKU_SEND_SCREENSHOT=true
DANMAKU_SAVE_API_IMAGES=true
DANMAKU_USE_DUMMY_API=true
